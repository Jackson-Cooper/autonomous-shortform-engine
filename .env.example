# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/content_engine

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# API Keys
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
PEXELS_API_KEY=your_pexels_api_key

# Storage
STORAGE_PATH=./storage/media
S3_BUCKET=your_bucket_name
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_ENDPOINT_URL=https://your-endpoint.com

# Social APIs (Placeholders)
TIKTOK_API_KEY=your_tiktok_key
INSTAGRAM_API_KEY=your_instagram_key
YOUTUBE_API_KEY=your_youtube_key
